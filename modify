	.owner		= THIS_MODULE,
	.name		= "RTL8211F timer",
	.max_adj	= S32_MAX,
	.n_alarm	= 0,
	.n_pins		= 0,
	.n_ext_ts	= 0,
	.n_per_out	= 0,
	.pps		= 0,
	.adjfreq	= rtl8211f_adjfreq,
