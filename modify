	.gettime64	= rtl8211f_gettime,
	.settime64	= rtl8211f_settime,
};

static int rtl8211f_ptp_probe(struct phy_device *phydev)
{
	struct rtl8211f_private *priv;
	struct rtl8211f_ptp *ptp;
	// struct device *ptp_parent = NULL;
	int ret;

	priv = devm_kzalloc(&phydev->mdio.dev, sizeof(*priv), GFP_KERNEL);
	if (!priv)
		return -ENOMEM;

	ptp = devm_kzalloc(&phydev->mdio.dev, sizeof(*ptp), GFP_KERNEL);
	if (!ptp)
		return -ENOMEM;

	ptp->rx_pool_data = devm_kcalloc(&phydev->mdio.dev, RTL8211F_MAX_RXTS,
					 sizeof(*ptp->rx_pool_data), GFP_KERNEL);
	if (!ptp->rx_pool_data)
		return -ENOMEM;

	ptp->phydev = phydev;
	INIT_DELAYED_WORK(&ptp->ts_work, rtl8211f_rx_timestamp_work);
	ptp->ts_wq = alloc_workqueue("rtl8211f-ptp-ts",
				     WQ_HIGHPRI | WQ_UNBOUND | WQ_MEM_RECLAIM,
				     1);
	if (!ptp->ts_wq)
		return -ENOMEM;
	INIT_LIST_HEAD(&ptp->rxts);
	INIT_LIST_HEAD(&ptp->rxpool);
	mutex_init(&ptp->ts_mutex);
	skb_queue_head_init(&ptp->tx_queue);
	skb_queue_head_init(&ptp->rx_queue);
	spin_lock_init(&ptp->rx_ts_lock);
	spin_lock_init(&ptp->tx_queue_lock);
	spin_lock_init(&ptp->rx_queue_lock);
	memcpy(&ptp->caps, &rtl8211f_caps, sizeof(ptp->caps));
	{
		int i;

		for (i = 0; i < RTL8211F_MAX_RXTS; i++)
			list_add_tail(&ptp->rx_pool_data[i].list, &ptp->rxpool);
	}

	priv->ptp = ptp;
	priv->mii_ts.rxtstamp = rtl8211f_rxtstamp;
	priv->mii_ts.txtstamp = rtl8211f_txtstamp;
	priv->mii_ts.hwtstamp = rtl8211f_hwtstamp;
	priv->mii_ts.ts_info = rtl8211f_ts_info;

	phydev->priv = priv;
	phydev->mii_ts = &priv->mii_ts;

	rtl8211f_sync_ethernet(phydev);

	/*
	 * Keep the legacy/non-PTP interrupt path fully masked so INTB only
	 * reflects the PTP timestamp sources we enable later.
	 * Also read back the status registers once to clear any stale latch.
	 */
	ret = phy_write_paged(phydev, 0xa42, RTL821x_INER, 0);
	if (ret < 0)
		goto err_out;
	ret = phy_read(phydev, RTL821x_INSR);
	if (ret < 0)
		goto err_out;
	ret = phy_read_paged(phydev, 0xa43, RTL8211F_INSR);
	if (ret < 0)
		goto err_out;
	
	//清除ptp功能，只保留使能后续进行重启
	ret = rtl8211f_write_page(phydev, RTL8211F_E40_PAGE, RTL8211F_PTP_CTL, RTL8211F_PTP_ENABLE);
	if (ret < 0)
		goto err_out;
	//重启
	rtl8211f_ptp_phy_reset(phydev);
	//重启后再配置寄存器
	{
		int oldpage;
		u16 val;

		oldpage = phy_select_page(phydev, RTL8211F_E40_PAGE);
		if (oldpage < 0) {
			ret = oldpage;
			goto err_out;
		}

		ret = rtl8211f_write_on_page(phydev, RTL8211F_PTP_INER,
					     RTL8211F_TX_TIMESTAMP |
					     RTL8211F_RX_TIMESTAMP);
		if (ret >= 0)
			ret = rtl8211f_read_on_page(phydev, RTL8211F_PTP_INER,
						    &val);
		ret = phy_restore_page(phydev, oldpage, ret);
		if (ret < 0)
			goto err_out;
	}

	ptp->ptp_clock = ptp_clock_register(&ptp->caps, &phydev->mdio.dev);
	if (IS_ERR(ptp->ptp_clock))
		goto err_out;
	/*
	 * Prefer the attached netdev as the PHC parent so userspace can map
	 * eth0 to /dev/ptpX through sysfs more reliably. Fall back to the PHY
	 * mdio device if the netdev is not attached yet.
	 * follow sector code will resource a cush
	 */

	/* ptp_parent = &phydev->mdio.dev;
	if (phydev->attached_dev)
		ptp_parent = &phydev->attached_dev->dev;
	
	RTL_PTP_DBG("RTL PTP: using netdev %s as PHC parent\n",
			    dev_name(&phydev->attached_dev->dev));

	ptp->ptp_clock = ptp_clock_register(&ptp->caps, ptp_parent);
	if (IS_ERR(ptp->ptp_clock))
		goto err_out; */
	
	

	ret = rtl8211f_ptp_irq_setup(ptp);
	if (ret)
		goto err_unregister_ptp_clock;
	return 0;

err_unregister_ptp_clock:
	if (ptp->ptp_clock && !IS_ERR(ptp->ptp_clock))
		ptp_clock_unregister(ptp->ptp_clock);
err_out:
	if (ptp->ts_wq)
		destroy_workqueue(ptp->ts_wq);
	return ret;
}

static void rtl8211f_ptp_remove(struct phy_device *phydev)
{
	struct rtl8211f_private *priv = phydev->priv;

	if (!priv || !priv->ptp)
		return;

	if (priv->ptp->irq_enabled)
		free_irq(priv->ptp->irq, priv->ptp);
	cancel_delayed_work_sync(&priv->ptp->ts_work);
	if (priv->ptp->ts_wq)
		destroy_workqueue(priv->ptp->ts_wq);
	if (priv->ptp->ptp_clock && !IS_ERR(priv->ptp->ptp_clock))
		ptp_clock_unregister(priv->ptp->ptp_clock);

	phydev->mii_ts = NULL;
}
