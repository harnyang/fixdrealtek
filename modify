/**
 * Enable sync ethernet function
 *
 * After phy link-up, the value of (page 0xa43, 0x1a) should be 0x302e,
 * and the value of (page 0xe40, 0x13) should be 0x1.
 */
void rtl8211f_sync_ethernet(struct phy_device *phydev)
{
	int oldpage, ret;
	u16 val;

	/* 
	 Harn note:
	 0x09 GBCR 寄存器 
	 bit 12: MASTER/SLAVE Manual Configuration Enable: Manual MASTER/SLAVE configuration
	 bit 11: default MASTER/SLAVE Mode: value 0 Slave mode 
	 Bit 9: 1000Base-T Full Duplex Capable: 
	                            value 1 Advertise 
	                            value 0 Do not advertise 
	*/

	phy_write(phydev, 0x09, 0x1200);
	/* 使能Sync-E 功能，此功能应用需要重启 */
	oldpage = phy_select_page(phydev, RTL8211F_E40_PAGE);
	if (oldpage < 0)
		return;

	ret = rtl8211f_read_on_page(phydev, RTL8211F_SYNCE_CTL, &val);
	if (ret < 0)
		goto out_restore;
	ret = rtl8211f_write_on_page(phydev, RTL8211F_SYNCE_CTL,
				     val | RTL8211F_SYNC_E_ENABLE);

out_restore:
	phy_restore_page(phydev, oldpage, ret);
}

static const char *rtl8211f_msg_name(u8 msg_type);

static int rtl8211f_get_trxstamp(struct ptp_clock_info *info, u8 msg_type,
				 bool rx, struct rtl8211f_trxstamp_meta *meta,
				 struct timespec64 *ts)
{
	struct rtl8211f_ptp *ptp = container_of(info, struct rtl8211f_ptp, caps);
	u64 __maybe_unused t_start, t_after_cmd, t_after_meta, t_after_sec, t_after_nsec;
	int oldpage, ret;
	u16 val;
#ifdef RTL8211F_PTP_PROFILE
	t_start = ktime_get_ns();
#endif
	val = RTL8211F_TRXTS_OVERWR_EN | (msg_type << 2) |
	      ((rx ? RTL8211F_TRXTS_RX : RTL8211F_TRXTS_TX) << 1) |
	      RTL8211F_TRXTS_RD;
	oldpage = phy_select_page(ptp->phydev, RTL8211F_E43_PAGE);
	if (oldpage < 0)
		return oldpage;

	ret = __phy_write(ptp->phydev, RTL8211F_PTP_TRX_TS_STA, val);
	if (ret < 0)
		goto out_restore;
#ifdef RTL8211F_PTP_PROFILE
	t_after_cmd = ktime_get_ns();
#endif
	ret = rtl821x_write_page(ptp->phydev, RTL8211F_E44_PAGE);
	if (ret < 0)
		goto out_restore;

	if (meta) {
		ret = rtl8211f_read_on_page(ptp->phydev,
					     RTL8211F_PTP_TRX_TS_INFO, &val);
		if (ret < 0)
			goto out_restore;
		meta->info = val;
		ret = rtl8211f_read_on_page(ptp->phydev,
					     RTL8211F_PTP_TRX_TS_SH, &val);
		if (ret < 0)
			goto out_restore;
		meta->sh = cpu_to_be16(val);
		ret = rtl8211f_read_on_page(ptp->phydev,
					     RTL8211F_PTP_TRX_TS_SID, &val);
		if (ret < 0)
			goto out_restore;
		meta->sid = cpu_to_be16(val);
		/*
		 * PTP_TRX_TS_INFO (page 0xe44, addr 0x10):
		 * [15:12] transportSpecific
		 * [11:8]  messageType
		 * [3:0]   versionPTP
		 */
		meta->transspec = FIELD_GET(RTL8211F_TRXTS_TRANSSPEC_MASK,
					     meta->info);
		meta->msgtype = FIELD_GET(RTL8211F_TRXTS_MSGTYPE_MASK,
					  meta->info);
		meta->ptpver = FIELD_GET(RTL8211F_TRXTS_PTPVER_MASK,
					 meta->info);
#ifdef RTL8211F_PTP_PROFILE
		t_after_meta = ktime_get_ns();
	} else {
		t_after_meta = t_after_cmd;
	}
#else 
	}
#endif

	ret = rtl8211f_read_on_page(ptp->phydev, RTL8211F_PTP_TRX_TS_S_HI,
				    &val);
	if (ret < 0)
		goto out_restore;
	ts->tv_sec = val;
	ret = rtl8211f_read_on_page(ptp->phydev, RTL8211F_PTP_TRX_TS_S_MI,
				    &val);
	if (ret < 0)
		goto out_restore;
	ts->tv_sec = (ts->tv_sec << 16) | val;
	ret = rtl8211f_read_on_page(ptp->phydev, RTL8211F_PTP_TRX_TS_S_LO,
				    &val);
	if (ret < 0)
		goto out_restore;
	ts->tv_sec = (ts->tv_sec << 16) | val;
#ifdef RTL8211F_PTP_PROFILE
	t_after_sec = ktime_get_ns();
#endif
	ret = rtl8211f_read_on_page(ptp->phydev, RTL8211F_PTP_TRX_TS_NS_HI,
				    &val);
	if (ret < 0)
		goto out_restore;
	ts->tv_nsec = val & 0x3fff;
	ret = rtl8211f_read_on_page(ptp->phydev, RTL8211F_PTP_TRX_TS_NS_LO,
				    &val);
	if (ret < 0)
		goto out_restore;
	ts->tv_nsec = (ts->tv_nsec << 16) | val;
#ifdef RTL8211F_PTP_PROFILE
	t_after_nsec = ktime_get_ns();
#endif
	ret = phy_restore_page(ptp->phydev, oldpage, 0);
	if (ret < 0)
		return ret;

	if (meta) {
		RTL_PTP_DBG("RTL ts-%s: req_msg=%u(%s) hw_msg=%u(%s) transspec=%u ptpver=%u info=0x%04x seq_id=0x%04x src_hash=0x%04x time=%lld.%09lu\n",
			rx ? "rx" : "tx",
			msg_type, rtl8211f_msg_name(msg_type),
			meta->msgtype, rtl8211f_msg_name(meta->msgtype),
			meta->transspec, meta->ptpver, meta->info,
			be16_to_cpu(meta->sid), be16_to_cpu(meta->sh),
			(long long)ts->tv_sec, ts->tv_nsec);
	} else {
		RTL_PTP_DBG("RTL ts-%s: req_msg=%u(%s) time=%lld.%09lu\n",
			rx ? "rx" : "tx", msg_type, rtl8211f_msg_name(msg_type),
			(long long)ts->tv_sec, ts->tv_nsec);
	}

	RTL_PTP_PERF("RTL ts-%s-lat: cmd=%lluns meta=%lluns sec=%lluns nsec=%lluns total=%lluns\n",
		rx ? "rx" : "tx",
		t_after_cmd - t_start,
		t_after_meta - t_after_cmd,
		t_after_sec - t_after_meta,
		t_after_nsec - t_after_sec,
		t_after_nsec - t_start);

	return 0;

out_restore:
	ret = phy_restore_page(ptp->phydev, oldpage, ret);
	dev_err_ratelimited(&ptp->phydev->mdio.dev,
			    "ptp trxstamp burst failed: msg=%u rx=%u ret=%d\n",
			    msg_type, rx, ret);

	return ret;
}

/**
 * @brief by packet ptphdr header calculate the hash.
 * 按 Realtek 应用说明中的规则计算 SourcePortIdentity hash：
 * 1. 将 8-byte clockIdentity 扩展为 10-byte SourcePortIdentity
 *    对 IEEE 1588 v1：在第 4/5 字节插入 0x00 0x00
 *    对 IEEE 1588 v2/802.1AS：直接拼接 8-byte clockIdentity + 2-byte sourcePortNumber
 * 2. 每 2 字节求和
 * 3. 将高 16-bit 与低 16-bit 相加，得到 16-bit hash
 */
static u16 rtl8211f_source_port_hash(struct rtl8211f_ptphdr *ptphdr)
{
	// u64 __maybe_unused cacul_hash_time_end = 0;
	// u64 __maybe_unused cacul_hash_time_start = ktime_get_ns();
	u8 spi[10];
	u32 sum;
	int i;

	if ((ptphdr->ver & 0xf) == 1) {
		memcpy(&spi[0], &ptphdr->clk_identity, 3);
		spi[3] = 0x00;
		spi[4] = 0x00;
		memcpy(&spi[5], ((u8 *)&ptphdr->clk_identity) + 3, 5);
	} else {
		memcpy(&spi[0], &ptphdr->clk_identity, 8);
		/*
		 * For IEEE 1588 v2 / 802.1AS, the PHY hashes the 10-byte
		 * SourcePortIdentity byte stream as it appears on the wire:
		 *   8-byte clockIdentity + 2-byte sourcePortNumber.
		 * src_port_id is already stored in network order in the PTP
		 * header, so copy the two bytes directly instead of rebuilding
		 * them through host-endian shifts.
		 */
		memcpy(&spi[8], &ptphdr->src_port_id, sizeof(ptphdr->src_port_id));
	}

	sum = 0;
	for (i = 0; i < ARRAY_SIZE(spi); i += 2)
		sum += ((u16)spi[i] << 8) | spi[i + 1];

	// cacul_hash_time_end = ktime_get_ns();
	// RTL_PTP_PERF("RTL source_port_hash lat: total=%lluns\n",
	// 	(cacul_hash_time_end - cacul_hash_time_start));

	return (sum & 0xffff) + (sum >> 16);
}
/**
 * @brief RX hadnle use this matching the skb ptphdr by meta data and msg_type 
 * 
 * @param ptphdr 
 * @param meta 
 * @param msg_type 
 * @return true 
 * @return false 
 */
static bool rtl8211f_match_hwstamp(struct rtl8211f_ptphdr *ptphdr,
				   const struct rtl8211f_trxstamp_meta *meta,
				   u8 msg_type)
{
	u16 src_port_hash;

	if (!ptphdr)
		return false;

	if ((ptphdr->tsmt & 0xf) != msg_type)
		return false;

	if (meta->msgtype != msg_type)
		return false;

	if (ptphdr->seq_id != meta->sid)
		return false;

	if (((ptphdr->tsmt >> 4) & 0xf) != meta->transspec)
		return false;

	if ((ptphdr->ver & 0xf) != meta->ptpver)
		return false;

	src_port_hash = rtl8211f_source_port_hash(ptphdr);
	if (src_port_hash != be16_to_cpu(meta->sh))
		return false;

	return true;
}
/**
 * @brief TX handle use this matching the ptphdr by meta data and msg_type
 * 
 * @param ptphdr 
 * @param meta 
 * @param msg_type 
 * @return true 
 * @return false 
 */
static __maybe_unused bool rtl8211f_match_tx_hwstamp(struct rtl8211f_ptphdr *ptphdr,
						     const struct rtl8211f_trxstamp_meta *meta,
						     u8 msg_type)
{
	u16 src_port_hash;

	if (!ptphdr)
		return false;

	if ((ptphdr->tsmt & 0xf) != msg_type)
		return false;

	if (ptphdr->seq_id != meta->sid)
		return false;

	src_port_hash = rtl8211f_source_port_hash(ptphdr);
	if (src_port_hash != be16_to_cpu(meta->sh))
		return false;
	
	return true;
}

static bool rtl8211f_rxts_expired(const struct rtl8211f_rxts *rxts)
{
	return time_after(jiffies, rxts->tmo);
}

static void rtl8211f_prune_rxts(struct rtl8211f_ptp *ptp)
{
	struct rtl8211f_rxts *rxts, *tmp;

	list_for_each_entry_safe(rxts, tmp, &ptp->rxts, list) {
		if (!rtl8211f_rxts_expired(rxts))
			break;

		list_del_init(&rxts->list);
		list_add_tail(&rxts->list, &ptp->rxpool);
	}
}

static bool rtl8211f_match_rxts_skb(struct sk_buff *skb,
				    enum hwtstamp_rx_filters filter,
				    const struct rtl8211f_rxts *rxts)
{
	struct rtl8211f_ptphdr *ptphdr;

	ptphdr = rtl8211f_get_ptp_header_rx(skb, filter);
	if (!ptphdr)
		return false;

	return rtl8211f_match_hwstamp(ptphdr, &rxts->meta, rxts->msg_type);
}

